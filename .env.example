# Optional external provider key for APILayer Number Verification.
# When omitted or when provider calls fail, FilterCalls uses the internal deterministic engine.
APILAYER_KEY=
ADMIN_TOKEN=

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# The Price ID for the Pro monthly plan (Stripe Dashboard > Products)
STRIPE_PRICE_PRO_MONTHLY=price_...

# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
