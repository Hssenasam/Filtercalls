# Optional external provider key for APILayer Number Verification.
# When omitted or when provider calls fail, FilterCalls uses the internal deterministic engine.
APILAYER_KEY=
ADMIN_TOKEN=

# Portal auth and email
SESSION_SECRET=replace-with-random-secret
CSRF_SECRET=replace-with-random-secret
PORTAL_BASE_URL=https://filtercalls.com
RESEND_API_KEY=replace-with-resend-api-key
EMAIL_FROM=FilterCalls <noreply@filtercalls.com>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe Billing
# Secret key from Stripe dashboard
STRIPE_SECRET_KEY=sk_live_example

# The Price ID for the Pro monthly plan
STRIPE_PRICE_PRO_MONTHLY=price_example

# Webhook signing secret from Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_example
